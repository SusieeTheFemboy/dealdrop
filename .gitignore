# Dependencies
node_modules/

# Build output
dist/
out/

# Electron packager cache
.cache/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor directories
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment / secrets
# (DealDrop stores all user config in the OS app data directory,
#  NOT in the project folder — but just in case anyone drops a .env here)
.env
.env.*
*.key
*.pem
secrets.*
config.local.*

# electron-store saves to the OS user data dir automatically.
# On Linux: ~/.config/dealdrop/
# On Windows: %APPDATA%\dealdrop\
# On macOS: ~/Library/Application Support/dealdrop/
# None of that ever touches this repo.
