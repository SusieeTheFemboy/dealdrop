{
  "name": "dealdrop",
  "version": "0.1.0",
  "description": "Steam sale & free game notifier",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux AppImage",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:all": "electron-builder -mwl"
  },
  "dependencies": {
    "electron-store": "^7.0.3"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.dealdrop.app",
    "productName": "DealDrop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "src/**",
      "assets/**",
      "node_modules/**"
    ],
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png",
      "category": "Utility",
      "description": "Steam sale & free game notifier"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.png",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.png"
    }
  }
}
